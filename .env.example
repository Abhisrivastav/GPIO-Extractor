# GPIO Extractor — environment configuration
# Copy this file to .env and fill in your values.
# ─────────────────────────────────────────────────────────────────────────────

# Intel ExpertGPT (recommended — works on Intel internal network / VPN)
EXPERGPT_BASE_URL=https://expertgpt.intel.com/v1
EXPERGPT_API_KEY=pak_<your-expergpt-key-here>

# ─────────────────────────────────────────────────────────────────────────────
# Azure OpenAI (alternative — requires private endpoint access)
# AZURE_OPENAI_ENDPOINT=https://<your-resource>.openai.azure.com/
# AZURE_OPENAI_KEY=<your-azure-key>
# AZURE_OPENAI_API_VERSION=2024-08-01-preview
# AZURE_OPENAI_DEPLOYMENT=gpt-4o

# ─────────────────────────────────────────────────────────────────────────────
# Intel corporate network settings (needed only when off VPN, for Azure path)
# HTTPS_PROXY=http://proxy-iind.intel.com:912/
# HTTP_PROXY=http://proxy-iind.intel.com:912/
# NO_PROXY=localhost,127.0.0.1,*.intel.com,expertgpt.intel.com
# SSL_CERT_FILE=C:\path\to\intel_certs.pem
# REQUESTS_CA_BUNDLE=C:\path\to\intel_certs.pem
